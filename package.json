{
  "name": "@agentteams/cli",
  "version": "0.1.74",
  "description": "CLI tool for AgentTeams API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agentteams": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --cache --cache-location .eslintcache --cache-strategy content",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "agentteams",
    "api"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentTeamsRun/cli.git"
  },
  "bugs": {
    "url": "https://github.com/AgentTeamsRun/cli/issues"
  },
  "homepage": "https://agentteams.run",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "axios": "^1.16.1",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "diff": "^8.0.4",
    "gray-matter": "^4.0.3",
    "open": "^10.1.0",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
